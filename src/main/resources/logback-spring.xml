<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProfile name="default,dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - correlationId=%X{correlationId} userId=%X{userId} plan=%X{userPlan} tenantId=%X{tenantId} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.saquero" level="DEBUG"/>
    </springProfile>

</configuration>